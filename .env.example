# Carbon Flow - ambiente local

# Frontend
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ASSISTANT_AI_ENABLED=false
NEXT_PUBLIC_API_URL=http://localhost:3333
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# API
NODE_ENV=development
API_PORT=3333
CORS_ORIGINS=http://localhost:3000
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWKS_URL=
DATABASE_URL=
ENABLE_SWAGGER=true

# Opcional: URL publica da API, usada para montar links externos quando necessario
API_PUBLIC_URL=http://localhost:3333

# Opcional: usado quando a API definir o usuario atual para funcoes/RLS do banco
SUPABASE_JWT_SECRET=

# Opcional: ativa a IA real do Carbon Assistant no backend
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Mercado Pago: assinatura do plano Pro
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_TEST_PAYER_USERNAME=
MERCADO_PAGO_TEST_PAYER_EMAIL=
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_WEBHOOK_URL=http://localhost:3333/webhooks/mercado-pago
MERCADO_PAGO_BACK_URL=http://localhost:3000/settings?section=billing
MERCADO_PAGO_PRO_PRICE=45
MERCADO_PAGO_CURRENCY_ID=BRL
